# Copy to .env and fill in. The app runs without these (local fallback ranker + simulated Slack).
# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model override. If your key 404s on this, try gemini-2.0-flash.
MODEL=gemini-2.5-flash
# --- Slack bot ---
# Bot User OAuth Token (xoxb-...) — OAuth & Permissions after installing the app.
SLACK_BOT_TOKEN=
# App-Level Token (xapp-...) — created when you enable Socket Mode, scope connections:write.
SLACK_APP_TOKEN=
